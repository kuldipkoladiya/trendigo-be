        {
          "name": "Create Seller Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"manager\",\n  \"products\": { \"view\": true, \"add\": true, \"update\": true, \"delete\": false },\n  \"orders\": { \"view\": true, \"add\": false, \"update\": true, \"delete\": false },\n  \"inventory\": { \"view\": true, \"add\": true, \"update\": true, \"delete\": true },\n  \"reviews\": { \"view\": true, \"add\": true, \"update\": false, \"delete\": false },\n  \"storeSettings\": { \"view\": true, \"add\": false, \"update\": false, \"delete\": false }\n}"
            },
            "url": {
              "raw": "{{base-url}}/v1/user/sellerRole",
              "host": [
                "{{base-url}}"
              ],
              "path": [
                "v1",
                "user",
                "sellerRole"
              ]
            }
          },
          "response": []
        },
